NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Optional: barcode lookup via Cosmos (Bluesoft) — Brazilian product database.
# Sign up at https://cosmos.bluesoft.com.br to get your token (free tier: 25 req/day).
# If empty, the app falls back to Open Food Facts (food/cosmetics only, no key needed).
COSMOS_API_TOKEN=

# Optional: URL do instalador desktop (página admin "Baixar app").
# Padrão: o asset "VendasApp-Instalador.exe" do último release no GitHub.
# Defina só se hospedar o .exe em outro lugar.
NEXT_PUBLIC_DESKTOP_DOWNLOAD_URL=

# === Relatório diário de fechamento por email (Vercel Cron às 20h BRT) ===
# Segredo que protege a rota /api/cron/daily-cash-close. A Vercel envia este
# valor automaticamente no header Authorization quando o cron dispara.
# Gere um valor aleatório longo (ex: openssl rand -hex 32).
CRON_SECRET=

# SMTP de envio. Para Gmail: host=smtp.gmail.com, port=465, user=seu@gmail.com,
# pass = uma "senha de app" (https://myaccount.google.com/apppasswords).
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=VendasApp <seu@gmail.com>
# Opcional: força TLS-na-conexão. Vazio = automático (true quando porta 465).
SMTP_SECURE=

# Para quem enviar o relatório. Admins com email REAL recebem automaticamente;
# como contas criadas no app usam usuário interno (sem caixa de entrada),
# defina aqui o seu email real para garantir o recebimento. Vários separados
# por vírgula.
REPORT_EMAIL=

# === Testes E2E (Playwright) ===
# Credenciais de uma conta admin de TESTE (nunca use a conta de produção).
# Crie um .env.test.local com esses valores — nunca commite credenciais reais.
E2E_ADMIN_EMAIL=admin-test@seudominio.com
E2E_ADMIN_PASSWORD=suasenha
# URL base usada pelos testes. Padrão: http://localhost:3000
PLAYWRIGHT_BASE_URL=http://localhost:3000
