NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Optional: barcode lookup via Cosmos (Bluesoft) — Brazilian product database.
# Sign up at https://cosmos.bluesoft.com.br to get your token (free tier: 25 req/day).
# If empty, the app falls back to Open Food Facts (food/cosmetics only, no key needed).
COSMOS_API_TOKEN=

# Optional: URL do instalador desktop (página admin "Baixar app").
# Padrão: o asset "VendasApp-Instalador.exe" do último release no GitHub.
# Defina só se hospedar o .exe em outro lugar.
NEXT_PUBLIC_DESKTOP_DOWNLOAD_URL=
